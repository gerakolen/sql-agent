# База данных
DB_TYPE=sqlite
DB_NAME=sample.db

# Для PostgreSQL:
# DB_TYPE=postgresql
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=your_database
# DB_USER=your_username
# DB_PASSWORD=your_password

# Конфигурация LLM
LLM_PROVIDER=
LLM_MODEL=
LLM_TEMPERATURE=
OPENAI_API_KEY=
BASE_URL=

# Агент
MAX_RESULTS=100
MAX_RETRIES=3
ENABLE_SQL_VALIDATION=true
SHOW_SQL=true
LANGUAGE=ru
